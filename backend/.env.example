# Azure Communication Services endpoint (required for SDK mode)
# Find this in Azure Portal > your ACS resource > Keys > Endpoint
ACS_ENDPOINT=https://<your-acs-resource-name>.communication.azure.com

# Sender email address from your CUSTOM VERIFIED domain (required)
# This must be a mailbox configured on a domain you verified in ACS Email
ACS_SENDER_ADDRESS=noreply@notifications.contoso.com

# Server port (optional, defaults to 3001)
PORT=3001

# Only set AZURE_CLIENT_ID if using a USER-ASSIGNED managed identity.
# Leave commented out for system-assigned managed identity or local dev.
# AZURE_CLIENT_ID=<your-user-assigned-managed-identity-client-id>

# ============================================================
# SMTP Configuration (optional — alternative to SDK mode)
# Requires an Entra ID App Registration with client secret.
# ============================================================
# Username format: <ACS-Resource-Name>.<Entra-App-ID>.<Entra-Tenant-ID>
# ACS_SMTP_USERNAME=my-acs-resource.12345678-abcd-efgh-ijkl-123456789012.87654321-dcba-hgfe-lkji-210987654321
# ACS_SMTP_PASSWORD=<your-entra-app-client-secret>
